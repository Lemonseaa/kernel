# Loop Harness runtime
LOOP_HARNESS_DB_PATH=/app/data/loop_harness.db
LOOP_HARNESS_DEFAULT_PROVIDER=minimax
LOOP_HARNESS_DRY_RUN=false

# MiniMax provider
LOOP_HARNESS_MINIMAX_API_KEY=
LOOP_HARNESS_MINIMAX_MODEL=MiniMax-M2.7-highspeed
LOOP_HARNESS_MINIMAX_BASE_URL=https://api.minimax.chat/v1
LOOP_HARNESS_MINIMAX_TIMEOUT_SECONDS=30
LOOP_HARNESS_MINIMAX_MAX_RETRIES=2

# OpenAI-compatible provider
LOOP_HARNESS_OPENAI_API_KEY=
LOOP_HARNESS_OPENAI_MODEL=gpt-4.1-mini
LOOP_HARNESS_OPENAI_BASE_URL=https://api.openai.com/v1
LOOP_HARNESS_OPENAI_TIMEOUT_SECONDS=30
LOOP_HARNESS_OPENAI_MAX_RETRIES=2

# Workflow and observability
LOOP_HARNESS_MAX_CONCURRENCY=1
LOOP_HARNESS_LLM_CACHE_ENABLED=true
LOOP_HARNESS_LLM_CACHE_MAX_SIZE=128
LOOP_HARNESS_LLM_CACHE_TTL_SECONDS=300
LOOP_HARNESS_SLOW_TASK_THRESHOLD_SECONDS=5
LOOP_HARNESS_SERVICE_HEARTBEAT_SECONDS=30

# Optional Redis service in docker-compose --profile redis
LOOP_HARNESS_REDIS_PORT=6379
