# OPC-OS runtime
OPC_OS_DB_PATH=/app/data/opc_os.db
OPC_OS_DEFAULT_PROVIDER=minimax
OPC_OS_DRY_RUN=false

# MiniMax provider
OPC_OS_MINIMAX_API_KEY=
OPC_OS_MINIMAX_MODEL=MiniMax-M2.7-highspeed
OPC_OS_MINIMAX_BASE_URL=https://api.minimax.chat/v1
OPC_OS_MINIMAX_TIMEOUT_SECONDS=30
OPC_OS_MINIMAX_MAX_RETRIES=2

# OpenAI-compatible provider
OPC_OS_OPENAI_API_KEY=
OPC_OS_OPENAI_MODEL=gpt-4.1-mini
OPC_OS_OPENAI_BASE_URL=https://api.openai.com/v1
OPC_OS_OPENAI_TIMEOUT_SECONDS=30
OPC_OS_OPENAI_MAX_RETRIES=2

# Workflow and observability
OPC_OS_MAX_CONCURRENCY=1
OPC_OS_LLM_CACHE_ENABLED=true
OPC_OS_LLM_CACHE_MAX_SIZE=128
OPC_OS_LLM_CACHE_TTL_SECONDS=300
OPC_OS_SLOW_TASK_THRESHOLD_SECONDS=5
OPC_OS_SERVICE_HEARTBEAT_SECONDS=30

# High availability
OPC_OS_HA_ENABLED=false
OPC_OS_INSTANCE_ID=opc-os-primary
OPC_OS_HA_LEASE_TTL_SECONDS=30
OPC_OS_HA_HEARTBEAT_SECONDS=10
OPC_OS_LB_PORT=8080

# Optional Redis service in docker-compose --profile redis
OPC_OS_REDIS_PORT=6379
