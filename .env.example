# Kernel runtime
KERNEL_DB_PATH=/app/data/kernel.db
KERNEL_DEFAULT_PROVIDER=minimax
KERNEL_DRY_RUN=false

# MiniMax provider
KERNEL_MINIMAX_API_KEY=
KERNEL_MINIMAX_MODEL=MiniMax-M2.7-highspeed
KERNEL_MINIMAX_BASE_URL=https://api.minimax.chat/v1
KERNEL_MINIMAX_TIMEOUT_SECONDS=30
KERNEL_MINIMAX_MAX_RETRIES=2

# OpenAI-compatible provider
KERNEL_OPENAI_API_KEY=
KERNEL_OPENAI_MODEL=gpt-4.1-mini
KERNEL_OPENAI_BASE_URL=https://api.openai.com/v1
KERNEL_OPENAI_TIMEOUT_SECONDS=30
KERNEL_OPENAI_MAX_RETRIES=2

# Workflow and observability
KERNEL_MAX_CONCURRENCY=1
KERNEL_LLM_CACHE_ENABLED=true
KERNEL_LLM_CACHE_MAX_SIZE=128
KERNEL_LLM_CACHE_TTL_SECONDS=300
KERNEL_SLOW_TASK_THRESHOLD_SECONDS=5
KERNEL_SERVICE_HEARTBEAT_SECONDS=30

# Optional Redis service in docker-compose --profile redis
KERNEL_REDIS_PORT=6379
