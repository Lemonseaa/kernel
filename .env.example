# checkpointAI runtime
CHECKPOINT_AI_DB_PATH=/app/data/checkpoint_ai.db
CHECKPOINT_AI_DEFAULT_PROVIDER=minimax
CHECKPOINT_AI_DRY_RUN=false

# MiniMax provider
CHECKPOINT_AI_MINIMAX_API_KEY=
CHECKPOINT_AI_MINIMAX_MODEL=MiniMax-M2.7-highspeed
CHECKPOINT_AI_MINIMAX_BASE_URL=https://api.minimax.chat/v1
CHECKPOINT_AI_MINIMAX_TIMEOUT_SECONDS=30
CHECKPOINT_AI_MINIMAX_MAX_RETRIES=2

# OpenAI-compatible provider
CHECKPOINT_AI_OPENAI_API_KEY=
CHECKPOINT_AI_OPENAI_MODEL=gpt-4.1-mini
CHECKPOINT_AI_OPENAI_BASE_URL=https://api.openai.com/v1
CHECKPOINT_AI_OPENAI_TIMEOUT_SECONDS=30
CHECKPOINT_AI_OPENAI_MAX_RETRIES=2

# Workflow and observability
CHECKPOINT_AI_MAX_CONCURRENCY=1
CHECKPOINT_AI_LLM_CACHE_ENABLED=true
CHECKPOINT_AI_LLM_CACHE_MAX_SIZE=128
CHECKPOINT_AI_LLM_CACHE_TTL_SECONDS=300
CHECKPOINT_AI_SLOW_TASK_THRESHOLD_SECONDS=5
CHECKPOINT_AI_SERVICE_HEARTBEAT_SECONDS=30

# Optional Redis service in docker-compose --profile redis
CHECKPOINT_AI_REDIS_PORT=6379
